   "source": [
    "import psutil\n",
    "import time\n",
    "\n",
    "while True:\n",
    "    cpu = psutil.cpu_percent(interval=1)\n",
    "    ram = psutil.virtual_memory().percent\n",
    "\n",
    "    print(\"CPU Usage:\", cpu, \"%\")\n",
    "    print(\"RAM Usage:\", ram, \"%\")\n",
    "    print(\"-----\")"
   ]
  }
